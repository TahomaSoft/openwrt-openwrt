include $(TOPDIR)/rules.mk
PKG_NAME:=rk3568-boot-meta
PKG_BUILD_DEPENDS:= arm-trusted-firmware-rockchip-rkbin/host uboot-rk356x
DEPENDS:= +arm-trusted-firmware-rockchip-rkbin/host +uboot-rk356x +u-boot-linkstar-h68k-rk3568
PKG_VERSION:=0
include $(INCLUDE_DIR)/package.mk


define Package/rk3568-boot-meta
 SECTION:=meta
 CATEGORY:=Image Helpers
 TITLE:= Meta package to build firmware for Rockchip-RK3568
